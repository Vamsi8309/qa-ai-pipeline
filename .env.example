# ── Jira ──────────────────────────────────────────────────
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=SCRUM
JIRA_ACCOUNT_ID=

# Corporate network SSL bypass (1 = verify certs, 0 = skip). Leave unset in cloud.
NODE_TLS_REJECT_UNAUTHORIZED=0

# ── AI (bug classification + duplicate detection) ─────────
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# ── Email ─────────────────────────────────────────────────
# smtp   → Gmail/SMTP (emails anyone, but blocked on many networks incl. Render)
# resend → Resend HTTP API (works in the cloud; sandbox sender only delivers to
#          the verified Resend account address until you verify a domain)
EMAIL_PROVIDER=resend

EMAIL_FROM=you@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password   # only used when EMAIL_PROVIDER=smtp
EMAIL_TO=developer@example.com               # bug-assigned notifications
TESTER_EMAIL=tester@example.com              # who reviews failures (Accept/Decline)
RESEND_API_KEY=your_resend_api_key

# ── Deployment ────────────────────────────────────────────
# Public base URL of THIS server — used in the Accept/Decline email links.
# Leave unset for local (http://localhost:PORT). On Render set to your app URL.
APP_BASE_URL=
# PORT is injected by the host (Render/Railway). Defaults to 3000 locally.
